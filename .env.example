# Copy to .env and fill in. Never commit .env.
# VPS access
VPS_HOST=your-vps-host
VPS_USER=ubuntu
SSH_KEY_PATH=infos/lighter.pem
SSH_KNOWN_HOSTS_PATH=
REMOTE_DIR=/home/ubuntu/passivbot_lighter
# Leave empty when REMOTE_DIR is a host path on the VPS. Set this to the
# remote bot container name when REMOTE_DIR exists only inside that container.
REMOTE_DOCKER_CONTAINER=

# Dashboard display
DISPLAY_BASELINE=800
SYMBOL=HYPE

# Collector
POLL_INTERVAL_SECONDS=3

# Backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8787
FRONTEND_DIST=frontend/dist
ENABLE_DEV_ROUTES=false
REQUIRE_SSH_ON_START=false

# Lighter market data
LIGHTER_WS_URL=wss://mainnet.zklighter.elliot.ai/stream

# Persistence
DATABASE_PATH=data/dashboard.db

# Logging
LOG_LEVEL=INFO

# Docker compose notes:
# - The compose file overrides BACKEND_HOST, DATABASE_PATH, SSH_KEY_PATH, and FRONTEND_DIST
#   for the container runtime.
# - The host SSH directory is mounted read-only at /run/secrets.
# - SQLite is stored in the dashboard-data Docker volume at /data/dashboard.db.
# - To use a different host key directory, uncomment and set:
# HOST_SSH_DIR=./infos
# - To enable strict SSH host verification in Docker, put known_hosts in HOST_SSH_DIR
#   and set:
# SSH_KNOWN_HOSTS_PATH=/run/secrets/known_hosts
#
# Docker runtime values, shown for reference:
# BACKEND_HOST=0.0.0.0
# DATABASE_PATH=/data/dashboard.db
# SSH_KEY_PATH=/run/secrets/lighter.pem
# FRONTEND_DIST=/app/frontend/dist
